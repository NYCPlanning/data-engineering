# Docker Compose Apps - Environment Variables
# For production: Run with `op run --env-file=.env -- ./scripts/start.sh`
# For local dev: Users should already have these set in root example.env

# AWS/DigitalOcean Spaces
AWS_S3_ENDPOINT=op://Data Engineering/DO_keys/AWS_S3_ENDPOINT
AWS_SECRET_ACCESS_KEY=op://Data Engineering/DO_keys/AWS_SECRET_ACCESS_KEY
AWS_ACCESS_KEY_ID=op://Data Engineering/DO_keys/AWS_ACCESS_KEY_ID

# DigitalOcean Spaces (MinIO-compatible)
SPACES_KEY=op://Data Engineering/DO_keys/AWS_ACCESS_KEY_ID
SPACES_SECRET=op://Data Engineering/DO_keys/AWS_SECRET_ACCESS_KEY
SPACES_ENDPOINT=op://Data Engineering/DO_keys/AWS_S3_ENDPOINT
#SPACES_BUCKET=op://Data Engineering/your_spaces_item/bucket

# Database
BUILD_ENGINE_SERVER=op://Data Engineering/EDM_DATA/server_url

# GitHub
GHP_TOKEN=op://Data Engineering/GITHUB_TOKENS/de_qa_app

# Socrata
SOCRATA_USER=op://Data Engineering/DCP_OpenData/username
SOCRATA_PASSWORD=op://Data Engineering/DCP_OpenData/password

# Nginx Basic Auth
NGINX_AUTH_USER=op://Data Engineering/de_tools_server/username
NGINX_AUTH_PASSWORD=op://Data Engineering/de_tools_server/password

# Nginx Domain (leave empty for IP-only access, set domain for SSL)
# When using SSL, also update server_name in nginx/conf.d/default.conf
NGINX_DOMAIN=de-qaqc.nycplanningdigital.com
